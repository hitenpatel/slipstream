    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "yjs": "13.6.21",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "2.1.8",
    "vitest": "2.1.8"
  }
}
