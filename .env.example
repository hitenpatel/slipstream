# Copy to .env (gitignored) and fill in real values. Never commit secrets.

# Cookie session secret — long random string. `openssl rand -hex 32` is fine.
SESSION_SECRET=

# Mongo URI — defaults match the bundled single-node replica set in docker-compose.
MONGODB_URI=mongodb://db:27017/slipstream?replicaSet=rs0

# Public origin the browser talks to. Used by the web app to build the sync URL.
NEXT_PUBLIC_SYNC_URL=https://tracker.hiten.dev
