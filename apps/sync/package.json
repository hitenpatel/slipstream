{
  "name": "@slipstream/sync",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'lint: sync (no rules wired yet)'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hono/node-server": "1.13.7",
    "@node-rs/argon2": "2.0.2",
    "@slipstream/protocol": "workspace:*",
    "hono": "4.6.13",
    "mongodb": "6.12.0",
    "ws": "8.18.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@types/ws": "8.5.13",
    "@vitest/coverage-v8": "2.1.8",
    "mongodb-memory-server": "10.1.4",
    "tsx": "4.19.2",
    "vitest": "2.1.8"
  }
}
